# =====================================================================
# Labkesda Garut LIS — Environment Variables
# Copy file ini jadi ".env" (tanpa .example), lalu isi nilainya.
# JANGAN commit file .env ke git.
# =====================================================================

# --- Supabase ------------------------------------------------------
# Ambil dari: Supabase Dashboard > Project Settings > API
#
# 1) Project URL  -> NEXT_PUBLIC_SUPABASE_URL
# 2) anon public key -> NEXT_PUBLIC_SUPABASE_ANON_KEY
# 3) service_role key (RAHASIA, jangan dibocorkan) -> SUPABASE_SERVICE_ROLE_KEY

NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi...ganti-dengan-anon-key"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi...ganti-dengan-service-role-key"

# --- Keamanan Session (JWT) ---------------------------------------
# WAJIB diganti sebelum produksi. Generate string acak, contoh:
#   openssl rand -base64 48
JWT_SECRET="ganti-dengan-string-acak-panjang-minimal-32-karakter"

# --- Aplikasi Mobile Pasien (opsional) ----------------------------
# JWT untuk akun pasien (app). Jika kosong, memakai JWT_SECRET.
PATIENT_JWT_SECRET=""

# Firebase Cloud Messaging — legacy server key untuk push notification
# ke aplikasi pasien. Kosongkan untuk menonaktifkan push (notifikasi
# tetap masuk inbox di dalam app).
FCM_SERVER_KEY=""

# WhatsApp gateway (mis. Fonnte / Baileys self-hosted) untuk kirim OTP.
# Endpoint HTTP POST menerima JSON { target, message }. Kosongkan untuk
# menonaktifkan pengiriman (OTP tetap tersimpan & bisa diverifikasi).
WA_GATEWAY_URL=""
